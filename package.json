{
  "name": "lytos-cli",
  "version": "0.9.0",
  "description": "CLI tool for Lytos — a human-first method for working with AI agents",
  "type": "module",
  "bin": {
    "lyt": "dist/cli.js",
    "lytos": "dist/cli.js",
    "lytos-cli": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && mkdir -p dist/method && cp -r method/. dist/method",
    "dev": "tsup --watch",
    "pretest": "tsup && mkdir -p dist/method && cp -r method/. dist/method",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lytos",
    "ai",
    "agents",
    "cli",
    "scaffold",
    "methodology",
    "skills",
    "memory",
    "rules"
  ],
  "author": "Frederic Galliné <frederic@galline.fr> (https://ubeez.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getlytos/lytos-cli.git"
  },
  "homepage": "https://lytos.org",
  "bugs": {
    "url": "https://github.com/getlytos/lytos-cli/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.14.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
